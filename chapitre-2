const questions=[
  {q:"Combien de machines sur un /26 ? Broadcast si réseau = 10.50.4.0 ?",hint:"2^(32-26)-2. Broadcast = dernière adresse.",keys:[['62'],['63','10.50.4.63']],correct:"Parfait. 6 bits hôtes → 64-2=62 machines. Broadcast=10.50.4.63.",partial:"62 machines OK. Broadcast = 10.50.4.63 (10.50.4.0 + 63).",wrong:"/26 → 6 bits hôtes → 2^6=64 → 64-2=62 machines. Broadcast=10.50.4.63."},
  {q:"Pourquoi deux entités ENGIE ne peuvent-elles pas avoir la même plage IP si interconnectées via SD-WAN ?",hint:"Table de routage du hub central.",keys:[['routage','route','conflit','chevauchement'],['sait pas','ambig','identiq','même']],correct:"Exact. Deux routes identiques dans la table → le hub ne sait plus vers quelle entité envoyer.",partial:"Bonne idée. Précise : deux routes identiques dans la table de routage = ambiguïté, le routeur ne peut pas décider.",wrong:"Si Roumanie et Italie ont la même plage, le hub a deux routes identiques. Il ne sait pas vers laquelle envoyer le trafic."},
  {q:"Pourquoi le port est-il indispensable dans le NAT quand plusieurs machines partagent une IP publique ?",hint:"Que se passe-t-il quand la réponse revient ?",keys:[['port','ticket','différenci'],['retour','réponse','identifi']],correct:"Parfait. Après NAT toutes les machines ont la même IP publique. Le port identifie la machine d'origine au retour.",partial:"Tu as l'idée. Le point clé : après NAT même IP publique pour tous → le port est le seul identifiant au retour.",wrong:"Après NAT, 10.50.4.10 et 10.50.4.11 ont toutes deux 203.0.113.1. Le port est le seul moyen de savoir à qui retourner la réponse."},
  {q:"Cite les 4 étapes DHCP dans l'ordre avec leur acronyme.",hint:"DORA. R = Request, pas Reply.",keys:[['discover','offer','request','acknowledge'],['dora']],correct:"Parfait. DORA : Discover → Offer → Request → Acknowledge.",partial:"L'ordre est là. Vérifie : R = Request (pas Reply). Acronyme = DORA.",wrong:"DORA : Discover (broadcast du PC) → Offer (serveur propose) → Request (PC accepte) → Acknowledge (serveur confirme)."},
  {q:"Quelle est la différence fondamentale entre OSPF et BGP ? Un cas d'usage ENGIE pour chacun.",hint:"L'un partage une carte, l'autre des annonces.",keys:[['ospf','interne','carte','datacenter'],['bgp','inter','annonce','sd-wan','opérateur']],correct:"Parfait. OSPF : carte complète, interne (datacenter). BGP : annonces de routes, inter-réseaux (SD-WAN 400 sites).",partial:"Tu as la distinction. Ajoute les cas ENGIE : OSPF pour le hub interne, BGP pour distribuer les routes SD-WAN.",wrong:"OSPF : carte complète, interne, secondes de convergence → datacenter ENGIE. BGP : annonces de routes, inter-réseaux, minutes → SD-WAN 400+ sites."},
  {q:"Qu'est-ce que la passerelle ? Quand un PC l'utilise-t-il ? Quel équipement joue ce rôle chez ENGIE ?",hint:"Porte de sortie du subnet. Même équipement que le routeur.",keys:[['passerelle','routeur','porte','sortie'],['subnet','réseau','hors','fortigate']],correct:"Exact. La passerelle = IP du routeur sur le LAN. Utilisée quand destination hors subnet. FortiGate chez ENGIE.",partial:"Bonne direction. Précise : passerelle = IP du routeur sur le LAN local. FortiGate joue ce rôle chez ENGIE.",wrong:"Passerelle = IP du routeur sur le réseau local. Le PC l'utilise quand la destination est hors de son subnet. C'est le FortiGate chez ENGIE."}
];

let checked=new Array(questions.length).fill(false);
let scores=new Array(questions.length).fill(null);
let rendered=false;

function renderQuiz(){
  if(rendered) return;
  rendered=true;
  const c=document.getElementById('quiz-container');
  questions.forEach((q,i)=>{
    const div=document.createElement('div');
    div.className='card';
    div.style.marginBottom='16px';
    div.innerHTML=`<p class="q-num">Question ${i+1}/${questions.length}</p><p class="q-text">${q.q}</p><p class="q-hint">Indice : ${q.hint}</p><textarea class="q-input" id="ans-${i}" placeholder="Ta réponse..."></textarea><button class="q-btn" onclick="check(${i})">Vérifier</button><button class="q-btn q-btn-sec" onclick="reveal(${i})">Correction</button><div class="feedback" id="fb-${i}"></div>`;
    c.appendChild(div);
  });
  const sum=document.createElement('div');
  sum.id='summary';sum.style.display='none';
  c.appendChild(sum);
}

function ev(a,keys){
  const t=a.toLowerCase();
  let m=0;
  for(const g of keys) if(g.some(k=>t.includes(k))) m++;
  return m===keys.length?'correct':m>=1?'partial':'wrong';
}

function check(i){
  const v=document.getElementById('ans-'+i).value.trim();
  if(!v) return;
  const r=ev(v,questions[i].keys);
  scores[i]=r;checked[i]=true;
  const fb=document.getElementById('fb-'+i);
  fb.className='feedback show '+r;
  fb.innerHTML=`<strong>${{correct:'✓ Correct',partial:'~ Partiel',wrong:'✗ À revoir'}[r]}</strong> — ${questions[i][r]}`;
  document.getElementById('qfill').style.width=(checked.filter(Boolean).length/questions.length*100)+'%';
  if(checked.every(Boolean)) summary();
}

function reveal(i){
  const fb=document.getElementById('fb-'+i);
  fb.className='feedback show partial';
  fb.innerHTML=`<strong>Correction :</strong> ${questions[i].wrong}`;
  if(!checked[i]){checked[i]=true;scores[i]='wrong';document.getElementById('qfill').style.width=(checked.filter(Boolean).length/questions.length*100)+'%';}
  if(checked.every(Boolean)) summary();
}

function summary(){
  const s=document.getElementById('summary');
  s.style.display='block';
  const c=scores.filter(x=>x==='correct').length;
  const p=scores.filter(x=>x==='partial').length;
  const pct=Math.round((c+p*0.5)/questions.length*100);
  s.innerHTML=`<div class="score-card"><div class="score-num">${pct}%</div><div class="score-label">${pct>=80?'Maîtrisé ✓':pct>=50?'En bonne voie':'À retravailler'}</div><div class="score-detail">${questions.map((q,i)=>`<div class="score-row"><span>Q${i+1} — ${q.q.substring(0,50)}...</span><span class="pill ${scores[i]==='correct'?'p-green':scores[i]==='partial'?'p-amber':'p-coral'}">${scores[i]==='correct'?'Correct':scores[i]==='partial'?'Partiel':'À revoir'}</span></div>`).join('')}</div></div>`;
}
</script>
